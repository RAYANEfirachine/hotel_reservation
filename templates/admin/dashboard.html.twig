{% extends 'base.html.twig' %}

{% block title %}LuxeStay | Admin Dashboard{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --gold: #c49a6c;
        --dark-blue: #1a1c23;
        --bg-light: #f4f7f6;
    }
    body { background-color: var(--bg-light); font-family: 'Inter', sans-serif; }
    .dashboard-container { padding: 40px; max-width: 1200px; margin: auto; }
    .welcome-header { margin-bottom: 40px; border-left: 5px solid var(--gold); padding-left: 20px; }
    .welcome-header h1 { font-family: 'Playfair Display', serif; color: var(--dark-blue); font-size: 2.5rem; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .stat-card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); transition: 0.3s; }
    .stat-card:hover { transform: translateY(-5px); }
    .stat-card h3 { font-size: 0.9rem; color: #888; text-transform: uppercase; letter-spacing: 1px; }
    .stat-card .value { font-size: 2rem; font-weight: bold; color: var(--dark-blue); margin-top: 10px; }

    .quick-actions { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
    .action-card {
        background: var(--dark-blue); color: white; padding: 40px; border-radius: 12px;
        text-decoration: none; display: flex; align-items: center; justify-content: space-between;
    }
    .action-card:hover { background: var(--gold); }
    .action-card i { font-size: 2rem; opacity: 0.5; }
    .action-card h2 { margin: 0; font-size: 1.5rem; }
</style>
{% endblock %}

{% block body %}
<div class="dashboard-container">
    <header class="welcome-header">
        <h1>Dashboard</h1>
        <p>Welcome back, Administrator. Here is what's happening at <strong>LuxeStay</strong> today.</p>
    </header>

    <div class="stats-grid">
        <div class="stat-card">
            <h3>Total Rooms</h3>
            <div class="value">24</div>
        </div>
        <div class="stat-card">
            <h3>Active Bookings</h3>
            <div class="value">12</div>
        </div>
        <div class="stat-card">
            <h3>Revenue (MTD)</h3>
            <div class="value">$14,250</div>
        </div>
    </div>

    <h2 style="margin-bottom: 20px; color: var(--dark-blue);">Quick Management</h2>
    <div class="quick-actions">
        <a href="{{ path('admin_room_index') }}" class="action-card">
            <div>
                <h2>Manage Rooms</h2>
                <p>Add, edit or remove hotel rooms</p>
            </div>
            <span>🏢</span>
        </a>

        <a href="#" class="action-card" style="opacity: 0.7; cursor: not-allowed;">
            <div>
                <h2>View Bookings</h2>
                <p>Track guest reservations (Coming Soon)</p>
            </div>
            <span>📅</span>
        </a>
    </div>
</div>
{% endblock %}
